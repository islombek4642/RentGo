# General
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
AUTO_DB_INIT=true

# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rentgo

# Security
JWT_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Logging
LOG_LEVEL=info

# Storage
UPLOAD_PATH=uploads/
